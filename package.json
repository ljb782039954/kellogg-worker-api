{
  "name": "kellogg-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply kellogg-frontend-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply kellogg-frontend-db --local",
    "db:studio": "wrangler d1 execute kellogg-frontend-db --local --command \"SELECT 1\"",
    "db:seed:kv:local": "node scripts/seed-kv.mjs http://localhost:8787 dev-admin-token",
    "db:seed:kv:remote": "node scripts/seed-kv.mjs https://kellogg-api.aimeexiang239.workers.dev kellogg-admin-token-Aimeexiang",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.98.0"
  }
}
